# =============================================================================
# Hermes -- Environment Variable Reference
# =============================================================================
# Usage:
#   cp .env.example .env
#   Fill in REQUIRED values. Leave OPTIONAL values or adjust as needed.
#   Load into your shell or process supervisor (Docker, systemd, etc.)
#
# Tags:
#   [REQUIRED]  Must be set for this feature to work.
#   [OPTIONAL]  Has a built-in default; override only when needed.
#   [DEV-ONLY]  Should NOT be set in production.
# =============================================================================


# =============================================================================
# CORE APPLICATION
# =============================================================================

# Set to production on public servers. Enables stricter webhook validation.
# [OPTIONAL] default: development
HERMES_ENV=development

# Public base URL -- used in OAuth callbacks, Stripe redirects, and email links.
# [REQUIRED in production] default: http://localhost:8080
APP_PUBLIC_BASE_URL=https://hermes.example.com

# Force HTTPS redirect at the app layer (set true behind a TLS-terminating proxy).
# [OPTIONAL] default: false (dev) / true (production profile)
APP_FORCE_HTTPS=false

# Enable HTTP Strict Transport Security (HSTS) header.
# [OPTIONAL] default: true
APP_ENABLE_HSTS=true

# Comma-separated CORS origins for cross-host React deployments.
# Leave blank when frontend is co-located on the same host as the backend.
# [OPTIONAL] default: (empty -- same-host assumed)
APP_CORS_ALLOWED_ORIGINS=


# =============================================================================
# DATABASE
# =============================================================================
# Dev default: H2 file-backed database -- no external DB required.
# Production: set APP_DB_* vars to switch to PostgreSQL.

# JDBC connection URL.
# [REQUIRED in production] default: jdbc:h2:file:./hermes_db_v2;AUTO_SERVER=TRUE
APP_DB_URL=jdbc:postgresql://localhost:5432/hermes

# JDBC driver class.
# [OPTIONAL] default: org.h2.Driver (dev) / org.postgresql.Driver (production)
APP_DB_DRIVER=org.postgresql.Driver

# Database username.
# [REQUIRED in production] default: sa (H2 dev default)
APP_DB_USERNAME=hermes_user

# Database password.
# [REQUIRED in production] default: (empty -- H2 dev default)
APP_DB_PASSWORD=your-postgres-password

# Hibernate DDL auto mode. Use validate or none in production.
# [OPTIONAL] default: update (dev) / validate (production profile)
APP_JPA_DDL_AUTO=validate


# =============================================================================
# SECURITY
# =============================================================================

# AES encryption key for at-rest secrets (Strava refresh tokens, Garmin passwords).
# Generate with: openssl rand -hex 32
# [REQUIRED] -- Strava and Garmin credential storage fails without this.
APP_DATA_ENCRYPTION_KEY=your-32-byte-hex-encryption-key


# =============================================================================
# GOOGLE OAUTH 2.0
# =============================================================================
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match APP_GOOGLE_REDIRECT_URI below.

# [REQUIRED for Google sign-in]
APP_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# [REQUIRED for Google sign-in]
APP_GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# OAuth callback URL. Must be registered in Google Cloud Console.
# [OPTIONAL] default: http://localhost:8080/api/auth/google/callback
APP_GOOGLE_REDIRECT_URI=https://hermes.example.com/api/auth/google/callback


# =============================================================================
# STRAVA OAUTH 2.0
# =============================================================================
# Create an API application at https://www.strava.com/settings/api
# Authorization callback domain must match your deployment host.

# [REQUIRED for Strava sync]
STRAVA_CLIENT_ID=your-strava-client-id

# [REQUIRED for Strava sync]
STRAVA_CLIENT_SECRET=your-strava-client-secret

# OAuth callback URL. Must match the Strava app authorization callback domain.
# [OPTIONAL] default: http://localhost:8080/api/auth/strava/callback
STRAVA_REDIRECT_URI=https://hermes.example.com/api/auth/strava/callback

# Strava webhook verify token. Same value passed as verify_token to the Strava API.
# Register: POST https://www.strava.com/api/v3/push_subscriptions
# [OPTIONAL] default: (empty -- webhook push disabled in dev)
STRAVA_WEBHOOK_VERIFY_TOKEN=your-strava-webhook-verify-token

# Background Strava sync poll interval in milliseconds.
# [OPTIONAL] default: 600000 (10 minutes)
STRAVA_SYNC_INTERVAL_MS=600000


# =============================================================================
# GARMIN CONNECT WELLNESS SYNC
# =============================================================================
# Garmin credentials are stored per-runner in the database (entered in the UI).
# These vars control the background scheduler behaviour only.

# Enable the background Garmin wellness sync scheduler.
# [OPTIONAL] default: true
GARMIN_WELLNESS_SYNC_ENABLED=true

# Poll interval in milliseconds.
# [OPTIONAL] default: 1800000 (30 minutes)
GARMIN_WELLNESS_SYNC_INTERVAL_MS=1800000

# Days of history to sync per regular scheduled run.
# [OPTIONAL] default: 30
GARMIN_WELLNESS_SYNC_DAYS_BACK=30

# Days of history to pull on a first sync.
# [OPTIONAL] default: 90
GARMIN_WELLNESS_SYNC_INITIAL_DAYS_BACK=90


# =============================================================================
# AI -- GEMINI (SHOE IMAGE SCANNING)
# =============================================================================
# Powers AI shoe mileage extraction from screenshots.
# Get a key at https://aistudio.google.com/app/apikey

# [REQUIRED for AI features]
APP_AI_API_KEY=your-gemini-api-key

# Model identifier for image scanning requests.
# [OPTIONAL] default: gemini-2.5-flash
APP_AI_MODEL=gemini-2.5-flash

# AI provider. Currently supported: gemini
# [OPTIONAL] default: gemini
APP_AI_PROVIDER=gemini

# Free-tier per-runner daily AI call limit (shoe scan).
# [OPTIONAL] default: 5
APP_AI_FREE_TIER_PER_RUNNER_DAILY_LIMIT=5

# Free-tier project-wide daily AI call cap.
# [OPTIONAL] default: 200
APP_AI_FREE_TIER_PROJECT_DAILY_LIMIT=200

# Reserve calls withheld from the project cap (ops headroom).
# [OPTIONAL] default: 20
APP_AI_FREE_TIER_PROJECT_DAILY_RESERVE=20


# =============================================================================
# AI -- COURSE MAP EXTRACTION (QWEN / LOCAL GPU)
# =============================================================================
# Local Qwen model pipeline for marathon route extraction from race PDFs/images.
# Only required when running the course-map pipeline with a local GPU.

# [OPTIONAL] default: qwen-local
APP_AI_COURSE_MAP_PROVIDER=qwen-local

# Max PDF pages rendered per extraction job.
# [OPTIONAL] default: 2
APP_AI_COURSE_MAP_PDF_RENDER_PAGE_LIMIT=2

# Qwen model identifier (HuggingFace repo ID or local path).
# [OPTIONAL] default: Qwen/Qwen2.5-VL-7B-Instruct
APP_ROUTE_EXTRACTION_QWEN_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct

# Device map for Qwen model loading (auto splits across available GPUs).
# [OPTIONAL] default: auto
APP_ROUTE_EXTRACTION_QWEN_DEVICE_MAP=auto

# HuggingFace cache directory for model weights.
# [OPTIONAL] default: (system HF cache)
APP_ROUTE_EXTRACTION_QWEN_CACHE_DIR=

# Python executable for the route-extraction worker.
# [OPTIONAL] default: python
APP_ROUTE_EXTRACTION_PYTHON_COMMAND=python

# Path to the Python OpenCV extraction script (step 2 of the pipeline).
# [OPTIONAL] default: (empty -- extraction step disabled)
APP_ROUTE_EXTRACTION_PYTHON_SCRIPT=

# Path to the persistent Qwen worker script (keeps model warm between jobs).
# [OPTIONAL] default: (empty -- model reloads per call)
APP_ROUTE_EXTRACTION_QWEN_WORKER_SCRIPT=

# Path to the Qwen route-parameter extraction script.
# [OPTIONAL] default: (empty)
APP_ROUTE_EXTRACTION_QWEN_PARAMETERS_SCRIPT=

# Path to the Qwen anchor-pixel extraction script.
# [OPTIONAL] default: (empty)
APP_ROUTE_EXTRACTION_QWEN_ANCHOR_SCRIPT=

# Path to the Qwen route-alignment script.
# [OPTIONAL] default: (empty)
APP_ROUTE_EXTRACTION_QWEN_ALIGNMENT_SCRIPT=

# Timeout for a single Qwen extraction call (seconds).
# [OPTIONAL] default: 300
APP_ROUTE_EXTRACTION_QWEN_TIMEOUT_SECONDS=300

# Timeout for the alignment step (seconds).
# [OPTIONAL] default: 720
APP_ROUTE_EXTRACTION_QWEN_ALIGNMENT_TIMEOUT_SECONDS=720

# Overall pipeline timeout (seconds).
# [OPTIONAL] default: 120
APP_ROUTE_EXTRACTION_TIMEOUT_SECONDS=120

# Directory where uploaded course-map images are stored.
# [OPTIONAL] default: course-map-images
APP_COURSE_MAP_UPLOAD_DIR=course-map-images


# =============================================================================
# GOOGLE MAPS GEOCODING
# =============================================================================
# Reverse-geocoding for race locations. Can reuse the Google OAuth project.

# [OPTIONAL] default: (empty -- geocoding disabled)
APP_GOOGLE_GEOCODING_API_KEY=your-google-maps-api-key


# =============================================================================
# OSRM ROUTE MATCHING
# =============================================================================
# Snaps extracted GPS waypoints to road networks.
# Self-host for production: https://project-osrm.org/

# [OPTIONAL] default: https://router.project-osrm.org
APP_ROUTE_MATCHING_OSRM_BASE_URL=https://router.project-osrm.org

# OSRM routing profile.
# [OPTIONAL] default: driving
APP_ROUTE_MATCHING_OSRM_PROFILE=driving


# =============================================================================
# AI AGENT -- LETTA (EXPERIMENTAL)
# =============================================================================
# Optional persistent AI agent layer. Leave blank to disable entirely.

# Letta server base URL.
# [OPTIONAL] default: (empty -- Letta disabled)
APP_AI_AGENT_LETTA_BASE_URL=

# Letta API key.
# [OPTIONAL] default: (empty)
APP_AI_AGENT_LETTA_API_KEY=

# Letta agent ID to bind to.
# [OPTIONAL] default: (empty)
APP_AI_AGENT_LETTA_AGENT_ID=


# =============================================================================
# STRIPE PAYMENTS
# =============================================================================
# Configure at https://dashboard.stripe.com/
# Use Stripe test keys locally and live keys in production only.

# Stripe secret key (server-side only -- never expose to the frontend).
# [REQUIRED for Stripe payments]
STRIPE_SECRET_KEY=your-stripe-secret-key

# Stripe webhook signing secret. Webhook endpoint: POST /api/billing/webhook
# [REQUIRED for Stripe payments]
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Stripe Price ID for the Pro monthly plan (price_xxx from Dashboard > Products).
# [REQUIRED for Stripe payments]
STRIPE_PRICE_PRO_MONTHLY=price_your-pro-monthly-price-id

# Human-readable price label shown in the UI.
# [OPTIONAL] default: (empty)
APP_BILLING_PRICE_LABEL=


# =============================================================================
# EMAIL / SMTP
# =============================================================================
# Required for email verification on password sign-up.
# If SPRING_MAIL_HOST is empty, verification is skipped (dev convenience only).

# SMTP server hostname.
# [REQUIRED for email verification]
SPRING_MAIL_HOST=smtp.example.com

# SMTP port. 587 = STARTTLS, 465 = SSL.
# [OPTIONAL] default: 587
SPRING_MAIL_PORT=587

# SMTP login username (usually the sending email address).
# [REQUIRED for email verification]
SPRING_MAIL_USERNAME=noreply@example.com

# SMTP login password or app password.
# [REQUIRED for email verification]
SPRING_MAIL_PASSWORD=your-smtp-password

# Sender address shown to recipients.
# [OPTIONAL] default: noreply@localhost
APP_MAIL_FROM=noreply@example.com


# =============================================================================
# RECAPTCHA (OPTIONAL SPAM PROTECTION)
# =============================================================================
# Google reCAPTCHA v3. Leave blank to disable challenge on sign-up / login.
# Create keys at https://www.google.com/recaptcha/admin

# [OPTIONAL] default: (empty -- reCAPTCHA disabled)
RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# [OPTIONAL] default: (empty -- reCAPTCHA disabled)
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Score threshold below which requests are rejected (0.0-1.0).
# [OPTIONAL] default: 0.5
RECAPTCHA_THRESHOLD=0.5


# =============================================================================
# REDIS (OPTIONAL CACHING)
# =============================================================================
# Not required. Enable for session or rate-limit caching in high-traffic deployments.

# Enable Redis integration.
# [OPTIONAL] default: false
APP_REDIS_ENABLED=false

# Namespace prefix for all Hermes Redis keys.
# [OPTIONAL] default: hermes
APP_REDIS_KEY_PREFIX=hermes


# =============================================================================
# ADMIN BOOTSTRAP [DEV-ONLY]
# =============================================================================
# Creates an admin account on first startup if both vars are set.
# Clear these vars after the admin account is created.

# [DEV-ONLY] [OPTIONAL] default: (empty -- no admin bootstrapped)
APP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# [DEV-ONLY] [OPTIONAL] default: (empty)
APP_BOOTSTRAP_ADMIN_PASSWORD=your-admin-bootstrap-password
